import SwiftUI

struct PageForum: View {
    var body: some View {
        VStack(spacing: 0) {
            // Header Section
            VStack(spacing: 0) {
                HStack {
                    VStack(alignment: .leading, spacing: 5) {
                        Text("Circl.")
                            .font(.largeTitle)
                            .fontWeight(.bold)
                            .foregroundColor(.white)
                        
                        // Filter Button directly under "Circl."
                        Button(action: {
                            // Action for Filter
                        }) {
                            HStack {
                                Image(systemName: "slider.horizontal.3")
                                    .foregroundColor(.white)
                                Text("Filter")
                                    .font(.headline)
                                    .foregroundColor(.white)
                            }
                        }
                    }
                    Spacer()
                    VStack(alignment: .trailing) {
                        Image(systemName: "person.circle.fill")
                            .resizable()
                            .frame(width: 50, height: 50)
                            .foregroundColor(.white)
                            .offset(x: -30) // Move the profile picture 7 pixels to the left
                        Text("Hello, Fragne")
                            .foregroundColor(.white)
                            .font(.headline)
                    }
                }
                .padding(.horizontal)
                
                Spacer(minLength: 10) // Adds 10 pixels of space before the header ends
            }
            .padding(.top, 15)
            .padding(.bottom, 10)
            .background(Color.customHex("004aad"))
            .frame(height: 120) // Consistent with the ProfilePage header height
            
            // Scrollable Second Section
            ScrollView {
                VStack(spacing: 10) {
                    ForEach(0..<20) { index in
                        Text("Forum Post \(index + 1)")
                            .font(.system(size: 18))
                            .frame(maxWidth: .infinity)
                            .padding()
                            .background(Color.white)
                            .cornerRadius(10)
                            .shadow(radius: 2)
                    }
                }
                .padding()
            }
            .background(Color(UIColor.systemGray4))
            
            // Footer Section (Integrated from ProfilePage)
            HStack(spacing: 15) {
                CustomCircleButton(iconName: "hand.raised.fill") // Handshake icon
                CustomCircleButton(iconName: "briefcase.fill") // Briefcase icon
                CustomCircleButton(iconName: "person.3.fill") // Community icon
                CustomCircleButton(iconName: "person.2.circle.fill") // Connection icon
                CustomCircleButton(iconName: "book.fill") // Book icon
            }
            .padding(.vertical, 10)
            .background(Color.white) // Explicitly set footer background to white
        }
        .edgesIgnoringSafeArea(.bottom)
    }
}

// Reusable CustomCircleButton View for Footer Icons
struct CustomCircleButton: View {
    let iconName: String

    var body: some View {
        Button(action: {
            // Define the button action here
        }) {
            Circle()
                .fill(Color.customHex("004aad"))
                .frame(width: 50, height: 50)
                .overlay(
                    Image(systemName: iconName)
                        .resizable()
                        .scaledToFit()
                        .frame(width: 25, height: 25)
                        .foregroundColor(.white)
                )
        }
    }
}

