import SwiftUI

struct Page5: View {
    @State private var birthday: String = ""
    @State private var isUnderage: Bool = false
    @State private var educationLevel: String? = nil
    @State private var institutionAttended: String = ""
    @State private var certifications: String = ""
    @State private var yearsOfExperience: String = ""
    @State private var personalityType: String = ""
    @State private var showInvalidPersonalityAlert: Bool = false

    let educationOptions = [
        "No Formal Education",
        "Some High School",
        "High School Graduate or Equivalent",
        "Some College / Associate Degree",
        "Bachelor’s Degree",
        "Master’s Degree",
        "Doctorate / PhD"
    ]

    var body: some View {
        ZStack {
            // Background Color
            Color(hexCode: "004aad")
                .edgesIgnoringSafeArea(.all)

            VStack(spacing: 20) {
                Spacer()

                // Title
                Text("Create Your Account")
                    .font(.system(size: 32, weight: .bold))
                    .foregroundColor(Color(hexCode: "ffde59"))

                // Separator
                Rectangle()
                    .frame(height: 2)
                    .foregroundColor(.white)
                    .padding(.horizontal, 40)

                // Section Title
                HStack {
                    Text("Personal Information")
                        .font(.system(size: 24, weight: .bold))
                        .foregroundColor(.white)
                    Spacer()
                }
                .padding(.horizontal, 40)
                .padding(.top, 20)

                // Input Fields
                VStack(spacing: 15) {
                    // Birthday Field with Automatic Slash Insertion
                    TextField("Birthday (MM/DD/YY)", text: $birthday)
                        .onChange(of: birthday) { _ in
                            formatBirthday()
                            validateAge()
                        }
                        .textFieldStyle(RoundedTextFieldStyle())
                        .frame(maxWidth: 300)
                        .alert("You must be 18 years or older to sign up.", isPresented: $isUnderage) {
                            Button("OK", role: .cancel) { }
                        }

                    // Education Level Dropdown (Matching Height and Width)
                    DropdownField(
                        placeholder: "Education Level",
                        options: educationOptions,
                        selectedOption: $educationLevel
                    )
                    .frame(maxWidth: 300, maxHeight: 50)

                    // Text Fields
                    TextField("Institution Attended", text: $institutionAttended)
                        .textFieldStyle(RoundedTextFieldStyle())
                        .frame(maxWidth: 300)

                    TextField("Certifications/Licenses", text: $certifications)
                        .textFieldStyle(RoundedTextFieldStyle())
                        .frame(maxWidth: 300)

                    TextField("Years of Experience", text: $yearsOfExperience)
                        .textFieldStyle(RoundedTextFieldStyle())
                        .frame(maxWidth: 300)

                    // Personality Type Field
                    TextField("Personality Type (XXXX-Y)", text: $personalityType)
                        .onChange(of: personalityType) { _ in validatePersonalityType() }
                        .textFieldStyle(RoundedTextFieldStyle())
                        .frame(maxWidth: 300)
                        .alert("Invalid Personality Type format. Use XXXX-Y.", isPresented: $showInvalidPersonalityAlert) {
                            Button("OK", role: .cancel) { }
                        }
                }
                .padding(.horizontal, 30)
                .padding(.top, 10)

                Spacer()

                // Next Button
                Button(action: {
                    // Add navigation action here
                }) {
                    Text("Next")
                        .font(.system(size: 24, weight: .bold))
                        .foregroundColor(Color(hexCode: "004aad"))
                        .frame(maxWidth: 300)
                        .padding(.vertical, 15)
                        .background(Color(hexCode: "ffde59"))
                        .cornerRadius(10)
                        .overlay(
                            RoundedRectangle(cornerRadius: 10)
                                .stroke(Color.white, lineWidth: 2)
                        )
                        .padding(.horizontal, 50)
                }

                Spacer()
            }
        }
    }

    // Format Birthday with Slashes
    private func formatBirthday() {
        // Remove any non-numeric characters and ensure a 6-character MMDDYY string
        let filtered = birthday.filter { $0.isNumber }
        let formatted = filtered.prefix(6).enumerated().map { (index, char) -> String in
            if index == 2 || index == 4 {
                return "/\(char)"
            } else {
                return String(char)
            }
        }.joined()
        birthday = formatted
    }

    // Validate Birthday and Age
    private func validateAge() {
        let dateFormatter = DateFormatter()
        dateFormatter.dateFormat = "MM/dd/yy"

        if let birthDate = dateFormatter.date(from: birthday) {
            let calendar = Calendar.current
            let age = calendar.dateComponents([.year], from: birthDate, to: Date()).year ?? 0
            isUnderage = age < 18
        } else {
            isUnderage = false
        }
    }

    // Validate Personality Type Format
    private func validatePersonalityType() {
        let regex = #"^[ESTJINFP]{4}-[AT]$"#
        if !personalityType.matches(regex) && !personalityType.isEmpty {
            showInvalidPersonalityAlert = true
        }
    }
}

// Custom Regex Extension
extension String {
    func matches(_ regex: String) -> Bool {
        return self.range(of: regex, options: .regularExpression) != nil
    }
}

// DropdownField Component
struct DropdownField2: View {
    var placeholder: String
    var options: [String]
    @Binding var selectedOption: String?

    var body: some View {
        Menu {
            ForEach(options, id: \.self) { option in
                Button(option) {
                    selectedOption = option
                }
            }
        } label: {
            ZStack {
                RoundedRectangle(cornerRadius: 10)
                    .fill(Color(.systemGray5))
                    .frame(height: 50)

                HStack {
                    Text(selectedOption ?? placeholder)
                        .foregroundColor(
                            selectedOption == nil ?
                                Color(hexCode: "004aad").opacity(0.6) :
                                Color(hexCode: "004aad")
                        )
                    Spacer()
                    Image(systemName: "chevron.down")
                        .foregroundColor(Color(hexCode: "004aad"))
                }
                .padding(.horizontal, 15)
            }
        }
    }
}

// Custom TextField Style
struct RoundedTextFieldStyle: TextFieldStyle {
    func _body(configuration: TextField<Self._Label>) -> some View {
        configuration
            .padding(15)
            .background(Color(hexCode: "d9d9d9"))
            .cornerRadius(10)
            .font(.system(size: 20))
            .foregroundColor(Color(hexCode: "004aad"))
    }
}

